{
  "name": "wumpiary",
  "version": "0.1.1",
  "private": true,
  "description": "Multi-account Discord wrapper — keep every account connected, notified, and isolated.",
  "author": "Willow Bloom <salixbloom@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salixbloom/wumpiary.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "boot": "electron-vite build && xvfb-run -a electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "npm run build && electron-builder --publish never",
    "package:dir": "npm run build && electron-builder --dir --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:all": "npm run build && electron-builder -mwl --publish never",
    "release": "npm run build && electron-builder --publish always"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.4.3",
    "zustand": "^4.5.0"
  }
}
